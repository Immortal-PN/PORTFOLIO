# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose to frontend

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=bcrypt-hash-of-your-password  # Generate: node -e "require('bcryptjs').hash('yourpass',10).then(console.log)"

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ─── Server (local dev only) ──────────────────────────────────────────────────
PORT=5000
